---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import CtaBlock from '../components/CtaBlock.astro';
import ImageOverlay from '../components/ImageOverlay.astro';

const about = await getEntry('about', 'about');
if (!about) throw new Error('Missing about content entry');
const { title, description, intro, bios, sas } = about.data;
---

<Base surface="dark" title={title} description={description}>
  {/* Intro */}
  <Section tone="dark">
    <div class="about-intro">
      <h1>{intro.heading}</h1>
      <div class="about-intro__body">
        {intro.body.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </Section>

  {bios.map((bio) => (
    <Section tone="dark">
      <article class={`bio ${bio.reverse ? 'bio--reverse' : ''}`.trim()}>
        <div class="bio__image" aria-hidden="true">
          <span>{bio.photoLabel}</span>
        </div>
        <div class="bio__body">
          <h2>{bio.name}</h2>
          <p class="bio__lede">{bio.lede}</p>
          {bio.body.map((p) => <p>{p}</p>)}
          <ul class="bio__trust" aria-label={`Brands ${bio.name.split(' ')[0]} has worked with`}>
            {bio.trustList.map((brand) => <li>{brand}</li>)}
          </ul>
        </div>
      </article>
    </Section>
  ))}

  {/* SAS */}
  <ImageOverlay image={sas.image} imageAlt={sas.imageAlt} body={sas.body} cta={sas.cta} />

  {/* Bottom CTA */}
  <Section tone="dark">
    <CtaBlock />
  </Section>
</Base>

<style>
  .about-intro {
    max-width: 56rem;
  }

  .about-intro h1 {
    font-size: var(--text-display-lg);
    max-width: 18ch;
    margin: 2rem 0 3rem;
    text-wrap: balance;
  }

  .about-intro__body {
    display: grid;
    gap: 1.5rem;
    max-width: 60ch;
  }

  .about-intro__body p {
    font-size: 1.125rem;
    line-height: 1.65;
    color: rgba(250, 250, 247, 0.78);
    margin: 0;
  }

  .bio {
    display: grid;
    gap: 3rem;
    padding-top: 4rem;
    border-top: 1px solid var(--color-hairline-dark);
  }

  @media (min-width: 900px) {
    .bio {
      grid-template-columns: 5fr 7fr;
      gap: 5rem;
      align-items: start;
    }

    .bio--reverse .bio__image {
      order: 2;
    }
  }

  .bio__image {
    aspect-ratio: 3 / 4;
    background: rgba(250, 250, 247, 0.04);
    border: 1px solid var(--color-hairline-dark);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 420px;
  }

  .bio__image span {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2rem;
    color: rgba(250, 250, 247, 0.35);
  }

  .bio__body h2 {
    margin: 1rem 0 2rem;
  }

  .bio__lede {
    font-size: 1.25rem;
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
    max-width: 38ch;
  }

  .bio__body > p {
    color: rgba(250, 250, 247, 0.75);
    line-height: 1.65;
    max-width: 60ch;
  }

  .bio__trust {
    list-style: none;
    padding: 2rem 0 0;
    margin: 2rem 0 0;
    border-top: 1px solid var(--color-hairline-dark);
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem 1rem;
  }

  .bio__trust li {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(250, 250, 247, 0.7);
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--color-hairline-dark);
    border-radius: 999px;
  }

</style>
