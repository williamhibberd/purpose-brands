---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import LogoStrip from '../components/LogoStrip.astro';
import ProofBar from '../components/ProofBar.astro';
import NumberedList from '../components/NumberedList.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CtaBlock from '../components/CtaBlock.astro';
import { bookCallHref, contact } from '../config';

const caseStudies = (await getCollection('case-studies', (c) => c.data.featured)).sort(
  (a, b) => a.data.order - b.data.order,
);

const testimonials = (await getCollection('testimonials', (t) => t.data.featured)).sort(
  (a, b) => a.data.order - b.data.order,
);

const proofStats = [
  { value: '200+', label: 'units sold per day' },
  { value: '8x', label: 'sales growth' },
  { value: '12', label: 'months as Best Seller' },
];

const howItWorks = [
  {
    title: 'We have a chat',
    body: "30 minutes. We'll ask about your brand, your Amazon, and what's not working.",
  },
  {
    title: 'We do a free audit',
    body: "We look at your listings, your ads, your storefront, and tell you what we'd change.",
  },
  {
    title: "If we're a fit, we get to work",
    body: 'Same day if you want. No 12-week onboarding.',
  },
];

const services = [
  {
    title: 'We run your Amazon',
    body: 'Day-to-day management of your Vendor or Seller account. Weekly updates. Monthly reporting. All the boring stuff that actually matters, handled.',
  },
  {
    title: "We spend your ad budget like it's ours",
    body: "Because wasting money on ads that don't convert is painful. We run your Sponsored Products, Brands, and Display — and we actually watch what's happening.",
  },
  {
    title: 'We make your Amazon look like your brand',
    body: "Storefronts, A+ content, product pages. Your Amazon should look as good as your website. Right now, it probably doesn't.",
  },
  {
    title: 'We get your products found',
    body: "Titles, bullets, keywords, images — optimised so people actually find you when they search. No dark arts. Just the work.",
  },
];
---

<Base surface="dark">
  {/* Hero */}
  <section class="hero">
    <div class="container-site hero__inner">
      <h1 class="hero__headline">
        "They get shit done."
      </h1>
      <p class="hero__attribution">— Eoin Keenan, Founder, Goodrays</p>
      <p class="hero__sub">
        We're Phoebe and Biraj. We run Amazon for brilliant brands.
        Two people. 15 years. No juniors.
      </p>
      <div class="hero__actions">
        <Button href={bookCallHref} variant="primary" size="lg">Let's have a chat</Button>
        <Button href="/work" variant="ghost">See the results →</Button>
      </div>
      <p class="hero__contact">
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
        <span aria-hidden="true">·</span>
        <a href={contact.phoneHref}>{contact.phone}</a>
      </p>
    </div>
  </section>

  {/* Proof bar */}
  <Section tone="dark">
    <ProofBar items={proofStats} />
  </Section>

  {/* Brand logos */}
  <div class="container-site">
    <LogoStrip />
  </div>

  {/* Client voices */}
  <Section tone="dark">
    <div class="section-head">
      <p class="eyebrow">In their words</p>
      <h2>Don't take our word for it.</h2>
    </div>
    <div class="testimonial-grid">
      {testimonials.map((t) => (
        <TestimonialCard
          quote={t.data.quote}
          shortQuote={t.data.shortQuote}
          author={t.data.author}
          title={t.data.title}
        />
      ))}
    </div>
  </Section>

  {/* Who we are */}
  <Section tone="dark">
    <div class="who-we-are">
      <div class="who-we-are__photo">
        <span class="who-we-are__placeholder" aria-hidden="true">Phoebe & Biraj</span>
      </div>
      <div class="who-we-are__body">
        <p class="eyebrow">Who we are</p>
        <h2>We're Phoebe and Biraj.</h2>
        <p>
          Phoebe spent 15 years at Moët Hennessy, Heineken, and Belvedere.
          Biraj built an Amazon brand from nothing and sold it for seven figures.
          We started Purpose Brands because every Amazon agency we met was either
          too big to care or too small to deliver.
        </p>
        <p>
          We only work with food, drink, and wellness brands. We only work on Amazon.
          And you only ever work with us. That's it.
        </p>
        <Button href="/about" variant="ghost">More about us →</Button>
      </div>
    </div>
  </Section>

  {/* How it works */}
  <Section tone="dark">
    <div class="section-head">
      <p class="eyebrow">How it works</p>
      <h2>Three steps. No faff.</h2>
    </div>
    <NumberedList items={howItWorks} columns={3} />
  </Section>

  {/* What we do */}
  <Section tone="dark">
    <div class="section-head">
      <p class="eyebrow">What we do</p>
      <h2>Four things, done properly.</h2>
    </div>
    <NumberedList items={services} columns={4} />
  </Section>

  {/* Results */}
  <Section tone="dark">
    <div class="section-head section-head--split">
      <div>
        <p class="eyebrow">Selected work</p>
        <h2>The receipts.</h2>
      </div>
      <Button href="/work" variant="secondary">All case studies →</Button>
    </div>
    <div class="case-grid">
      {caseStudies.map((c) => (
        <CaseStudyCard
          href={`/work/${c.id}`}
          brand={c.data.brand}
          headline={c.data.headline}
          heroStat={c.data.heroStat}
        />
      ))}
    </div>
  </Section>

  {/* Final CTA */}
  <Section tone="dark">
    <CtaBlock dualCta />
  </Section>
</Base>

<style>
  .hero {
    padding-block: clamp(6rem, 10vw, 12rem) clamp(4rem, 6vw, 6rem);
  }

  .hero__headline {
    max-width: 18ch;
    text-wrap: balance;
    margin: 0 0 1rem;
  }

  .hero__attribution {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: rgba(250, 250, 247, 0.6);
    margin: 0 0 2.5rem;
  }

  .hero__sub {
    max-width: 58ch;
    font-size: 1.125rem;
    line-height: 1.55;
    color: rgba(250, 250, 247, 0.75);
    margin: 0 0 3rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .hero__contact {
    font-size: 0.9375rem;
    color: rgba(250, 250, 247, 0.6);
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0;
  }

  .hero__contact a:hover {
    color: var(--color-surface);
  }

  .section-head {
    margin-bottom: 4rem;
    max-width: 42rem;
  }

  .section-head--split {
    max-width: none;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: end;
    justify-content: space-between;
  }

  .section-head .eyebrow {
    margin: 0 0 1rem;
  }

  .section-head h2 {
    margin: 0;
    text-wrap: balance;
  }

  .who-we-are {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .who-we-are {
      grid-template-columns: 5fr 6fr;
      gap: 4rem;
    }
  }

  .who-we-are__photo {
    aspect-ratio: 4 / 5;
    background: rgba(250, 250, 247, 0.04);
    border: 1px solid var(--color-hairline-dark);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .who-we-are__placeholder {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-mute);
  }

  .who-we-are__body .eyebrow {
    margin: 0 0 1rem;
  }

  .who-we-are__body h2 {
    margin: 0 0 1.5rem;
  }

  .who-we-are__body p {
    color: rgba(250, 250, 247, 0.75);
    max-width: 52ch;
    margin: 0 0 1.5rem;
  }

  .testimonial-grid {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .testimonial-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .case-grid {
    display: grid;
    gap: 3rem 2rem;
  }

  @media (min-width: 768px) {
    .case-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
