---
import { getCollection, getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import LogoStrip from '../components/LogoStrip.astro';
import ProofBar from '../components/ProofBar.astro';
import NumberedList from '../components/NumberedList.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CtaBlock from '../components/CtaBlock.astro';
import { getSettings, bookCallHref } from '../lib/site';

const home = await getEntry('home', 'home');
if (!home) throw new Error('Missing home content entry');
const { hero, proofStats, testimonialsSection, whoWeAre, howItWorks, services, caseStudies: caseStudiesSection } =
  home.data;

const settings = await getSettings();
const ctaHref = bookCallHref(settings.calendly);

const caseStudies = (await getCollection('case-studies', (c) => c.data.featured)).sort(
  (a, b) => a.data.order - b.data.order,
);

const testimonials = (await getCollection('testimonials', (t) => t.data.featured)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base surface="dark">
  {/* Hero */}
  <section class="hero">
    <div class="container-site hero__inner">
      <h1 class="hero__headline">{hero.headline}</h1>
      <p class="hero__sub">{hero.sub}</p>
      <div class="hero__actions">
        <Button href={ctaHref} variant="primary" size="lg">{hero.primaryCtaLabel}</Button>
        <Button href={hero.secondaryCtaHref} variant="ghost">{hero.secondaryCtaLabel}</Button>
      </div>
    </div>
  </section>

  {/* Proof bar */}
  <Section tone="dark">
    <ProofBar items={proofStats} />
  </Section>

  {/* Brand logos */}
  <div class="container-site">
    <LogoStrip />
  </div>

  {/* Client voices */}
  <Section tone="dark">
    <div class="section-head">
      <h2>{testimonialsSection.heading}</h2>
    </div>
    <div class="testimonial-grid">
      {testimonials.map((t) => (
        <TestimonialCard
          quote={t.data.quote}
          shortQuote={t.data.shortQuote}
          author={t.data.author}
          title={t.data.title}
        />
      ))}
    </div>
  </Section>

  {/* Who we are */}
  <Section tone="dark">
    <div class="who-we-are">
      <div class="who-we-are__photo">
        <span class="who-we-are__placeholder" aria-hidden="true">{whoWeAre.photoLabel}</span>
      </div>
      <div class="who-we-are__body">
        <h2>{whoWeAre.heading}</h2>
        {whoWeAre.body.map((p) => <p>{p}</p>)}
        <Button href={whoWeAre.ctaHref} variant="ghost">{whoWeAre.ctaLabel}</Button>
      </div>
    </div>
  </Section>

  {/* How it works */}
  <Section tone="dark">
    <div class="section-head">
      <h2>{howItWorks.heading}</h2>
    </div>
    <NumberedList items={howItWorks.items} columns={3} />
  </Section>

  {/* What we do */}
  <Section tone="dark">
    <div class="section-head">
      <h2>{services.heading}</h2>
    </div>
    <NumberedList items={services.items} columns={4} />
  </Section>

  {/* Results */}
  <Section tone="dark">
    <div class="section-head section-head--split">
      <div>
        <h2>{caseStudiesSection.heading}</h2>
      </div>
      <Button href={caseStudiesSection.ctaHref} variant="secondary">{caseStudiesSection.ctaLabel}</Button>
    </div>
    <div class="case-grid">
      {caseStudies.map((c) => (
        <CaseStudyCard
          href={`/work/${c.id}`}
          brand={c.data.brand}
          headline={c.data.headline}
          heroStat={c.data.heroStat}
        />
      ))}
    </div>
  </Section>

  {/* Final CTA */}
  <Section tone="dark">
    <CtaBlock />
  </Section>
</Base>

<style>
  .hero {
    padding-block: clamp(6rem, 10vw, 12rem) clamp(4rem, 6vw, 6rem);
  }

  .hero__headline {
    max-width: 18ch;
    text-wrap: balance;
    margin: 0 0 1rem;
  }

  .hero__sub {
    max-width: 58ch;
    font-size: 1.125rem;
    line-height: 1.55;
    color: rgba(250, 250, 247, 0.75);
    margin: 0 0 3rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .section-head {
    margin-bottom: 4rem;
    max-width: 42rem;
  }

  .section-head--split {
    max-width: none;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: end;
    justify-content: space-between;
  }

  .section-head .eyebrow {
    margin: 0 0 1rem;
  }

  .section-head h2 {
    margin: 0;
    text-wrap: balance;
  }

  .who-we-are {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .who-we-are {
      grid-template-columns: 5fr 6fr;
      gap: 4rem;
    }
  }

  .who-we-are__photo {
    aspect-ratio: 4 / 5;
    background: rgba(250, 250, 247, 0.04);
    border: 1px solid var(--color-hairline-dark);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .who-we-are__placeholder {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-mute);
  }

  .who-we-are__body .eyebrow {
    margin: 0 0 1rem;
  }

  .who-we-are__body h2 {
    margin: 0 0 1.5rem;
  }

  .who-we-are__body p {
    color: rgba(250, 250, 247, 0.75);
    max-width: 52ch;
    margin: 0 0 1.5rem;
  }

  .testimonial-grid {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .testimonial-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .case-grid {
    display: grid;
    gap: 3rem 2rem;
  }

  @media (min-width: 768px) {
    .case-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
