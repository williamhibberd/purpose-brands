---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';

const notFound = await getEntry('notFound', 'not-found');
if (!notFound) throw new Error('Missing notFound content entry');
const { title, eyebrow, heading, sub, primaryCta, secondaryCta } = notFound.data;
---

<Base surface="dark" title={title} noindex>
  <section class="notfound">
    <div class="container-site">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{heading}</h1>
      <p class="notfound__sub">{sub}</p>
      <div class="notfound__actions">
        <Button href={primaryCta.href} variant="primary" size="lg">{primaryCta.label}</Button>
        <Button href={secondaryCta.href} variant="ghost">{secondaryCta.label}</Button>
      </div>
    </div>
  </section>
</Base>

<style>
  .notfound {
    padding-block: clamp(6rem, 12vw, 12rem);
  }

  .notfound h1 {
    font-size: var(--text-display-lg);
    max-width: 20ch;
    margin: 1.5rem 0 1.5rem;
  }

  .notfound__sub {
    font-size: 1.125rem;
    color: rgba(250, 250, 247, 0.7);
    margin: 0 0 3rem;
    max-width: 48ch;
  }

  .notfound__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    align-items: center;
  }
</style>
