---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import CalendlyEmbed from '../components/CalendlyEmbed.astro';
import { getSettings, getPrimaryContact } from '../lib/site';

const contactPage = await getEntry('contact', 'contact');
if (!contactPage) throw new Error('Missing contact content entry');
const { title, description, head, calendlyLabel, form, details } = contactPage.data;

const settings = await getSettings();
const primary = await getPrimaryContact();
---

<Base surface="dark" title={title} description={description}>
  <Section tone="dark">
    <div class="contact-head">
      <p class="eyebrow">{head.eyebrow}</p>
      <h1>{head.heading}</h1>
      <p class="contact-head__sub">{head.sub}</p>
    </div>

    <div class="contact-grid">
      {/* Left: Calendly */}
      <div class="contact-col">
        <p class="eyebrow contact-calendly-label">{calendlyLabel}</p>
        <CalendlyEmbed />
      </div>

      {/* Right: form + details */}
      <div class="contact-col">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="contact-form"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="contact-form__hp" aria-hidden="true">
            <label>
              {form.honeypotLabel}
              <input name="bot-field" tabindex="-1" autocomplete="off" />
            </label>
          </p>

          {form.fields.map((f) => (
            <div class="contact-form__field">
              <label for={f.id}>
                {f.label}
                {f.optionalLabel && <span> {f.optionalLabel}</span>}
              </label>
              {f.type === 'textarea' ? (
                <textarea id={f.id} name={f.id} rows={f.rows ?? 5} required={f.required}></textarea>
              ) : (
                <input
                  id={f.id}
                  name={f.id}
                  type={f.type}
                  autocomplete={f.autocomplete}
                  required={f.required}
                />
              )}
            </div>
          ))}

          <button type="submit" class="contact-form__submit">{form.submitLabel}</button>
        </form>

        <ul class="contact-details" aria-label="Contact details">
          <li>
            <span class="eyebrow">{details.emailLabel}</span>
            <a href={`mailto:${primary.email}`}>{primary.email}</a>
          </li>
          <li>
            <span class="eyebrow">{details.phoneLabel}</span>
            <a href={primary.phoneHref}>{primary.phone}</a>
          </li>
          <li>
            <span class="eyebrow">{details.linkedinLabel}</span>
            <a href={settings.linkedin} rel="me noopener">{details.linkedinText}</a>
          </li>
        </ul>
      </div>
    </div>
  </Section>
</Base>

<style>
  .contact-head {
    max-width: 48rem;
    margin-bottom: 5rem;
  }

  .contact-head h1 {
    font-size: var(--text-display-lg);
    margin: 1.5rem 0 2rem;
  }

  .contact-head__sub {
    font-size: 1.125rem;
    color: rgba(250, 250, 247, 0.75);
    max-width: 58ch;
    margin: 0;
  }

  .contact-grid {
    display: grid;
    gap: 4rem;
  }

  @media (min-width: 1000px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }

  .contact-details {
    list-style: none;
    padding: 3rem 0 0;
    margin: 3rem 0 0;
    border-top: 1px solid var(--color-hairline-dark);
    display: grid;
    gap: 1.5rem;
  }

  .contact-details li {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact-details a {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
  }

  .contact-details a:hover {
    color: var(--color-brand-purple);
  }

  .contact-form {
    display: grid;
    gap: 1.5rem;
  }

  .contact-form__hp {
    position: absolute;
    left: -9999px;
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-form__field label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 400;
    color: rgba(250, 250, 247, 0.6);
  }

  .contact-form__field label span {
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.7;
  }

  .contact-form__field input,
  .contact-form__field textarea {
    background: rgba(250, 250, 247, 0.04);
    border: 1px solid var(--color-hairline-dark);
    border-radius: 10px;
    padding: 0.875rem 1rem;
    color: var(--color-surface);
    font: inherit;
    font-size: 1rem;
    width: 100%;
  }

  .contact-form__field input:focus,
  .contact-form__field textarea:focus {
    outline: none;
    border-color: var(--color-brand-purple);
    background: rgba(91, 46, 224, 0.05);
  }

  .contact-form__field textarea {
    resize: vertical;
    min-height: 140px;
  }

  .contact-form__submit {
    justify-self: start;
    background: var(--color-brand-purple);
    color: white;
    border: none;
    padding: 1rem 2rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: background 140ms ease, transform 200ms ease;
  }

  .contact-form__submit:hover {
    background: var(--color-brand-purple-hover);
    transform: translateY(-1px);
  }

  .contact-calendly-label {
    margin: 0 0 1rem;
  }
</style>
