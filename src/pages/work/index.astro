---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/Section.astro';
import CaseStudyLong from '../../components/CaseStudyLong.astro';
import CtaBlock from '../../components/CtaBlock.astro';

const workPage = await getEntry('work', 'work');
if (!workPage) throw new Error('Missing work content entry');
const { title, description, head, cta } = workPage.data;

const caseStudies = (await getCollection('case-studies')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base surface="dark" title={title} description={description}>
  <Section tone="dark">
    <div class="work-head">
      <h1>{head.heading}</h1>
      <p class="work-head__sub">{head.sub}</p>
    </div>

    <div class="work-list">
      {caseStudies.map((c, i) => (
        <CaseStudyLong
          brand={c.data.brand}
          regions={c.data.regions}
          engagement={c.data.engagement}
          challenge={c.data.challenge}
          whatWeDid={c.data.whatWeDid}
          results={c.data.results}
          pullQuote={c.data.pullQuote}
          href={`/work/${c.id}`}
          reverse={i % 2 === 1}
        />
      ))}
    </div>
  </Section>

  <Section tone="dark">
    <CtaBlock headline={cta.headline} subtext={cta.subtext} />
  </Section>
</Base>

<style>
  .work-head {
    max-width: 42rem;
    margin-bottom: 5rem;
  }

  .work-head h1 {
    font-size: var(--text-display-lg);
    margin: 1.5rem 0 2rem;
    text-wrap: balance;
  }

  .work-head__sub {
    font-size: 1.125rem;
    color: rgba(250, 250, 247, 0.75);
    max-width: 56ch;
    margin: 0;
  }

  .work-list {
    border-top: 1px solid var(--color-hairline-dark);
  }

  :global(.work-list .case-long) {
    border-bottom-color: var(--color-hairline-dark);
  }
</style>
