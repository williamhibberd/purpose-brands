---
import Button from './Button.astro';
import { getSettings } from '../lib/site';

interface Props {
  headline?: string;
  subtext?: string;
}

const settings = await getSettings();

const {
  headline = settings.cta.defaultHeadline,
  subtext = settings.cta.defaultSubtext,
} = Astro.props;
---

<div class="cta-block">
  <h2 class="cta-block__headline">{headline}</h2>
  <p class="cta-block__subtext">{subtext}</p>
  <div class="cta-block__actions">
    <Button href={settings.cta.href} variant="primary" size="lg">{settings.cta.label}</Button>
  </div>
</div>

<style>
  .cta-block {
    text-align: center;
    max-width: 44rem;
    margin-inline: auto;
  }

  .cta-block__headline {
    font-size: var(--text-display-lg);
    line-height: 1.05;
    margin: 0 0 1.5rem;
    text-wrap: balance;
  }

  .cta-block__subtext {
    font-size: 1.125rem;
    color: var(--color-ink-mute);
    margin: 0 0 2.5rem;
    max-width: 38ch;
    margin-inline: auto;
  }

  :global(.section--dark) .cta-block__subtext {
    color: rgba(250, 250, 247, 0.7);
  }

  .cta-block__actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
</style>
