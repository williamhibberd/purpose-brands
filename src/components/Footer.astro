---
import Logo from '../assets/brand/logo.svg';
import { contact, nav, site } from '../config';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-site site-footer__inner">
    <div class="site-footer__brand">
      <Logo class="site-footer__mark" role="img" aria-label={site.name} />
      <p class="site-footer__tagline">
        Your Amazon agency for food, drink, and wellness brands.
      </p>
      <div class="site-footer__badge" aria-hidden="true">
        <span>SAS</span>
        <span>Ocean Network</span>
      </div>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      <h2>Site</h2>
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__contact">
      <h2>Contact</h2>
      <ul>
        <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>
        <li><a href={contact.phoneHref}>{contact.phone}</a></li>
        <li><a href={contact.linkedin} rel="me noopener">LinkedIn</a></li>
      </ul>
    </div>
  </div>

  <div class="container-site site-footer__meta">
    <p>© {year} {site.name}</p>
    <p>Made on the South Devon coast.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface-dark);
    color: var(--color-surface);
    padding: 5rem 0 2rem;
    margin-top: var(--spacing-section);
  }

  .site-footer__inner {
    display: grid;
    gap: 3rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--color-hairline-dark);
  }

  @media (min-width: 768px) {
    .site-footer__inner {
      grid-template-columns: 2fr 1fr 1fr;
      gap: 4rem;
    }
  }

  .site-footer__mark {
    display: block;
    width: clamp(160px, 22vw, 220px);
    height: auto;
    color: var(--color-brand-purple);
    margin-bottom: 1.5rem;
  }

  .site-footer__tagline {
    max-width: 32ch;
    color: rgba(250, 250, 247, 0.7);
    margin-bottom: 2rem;
  }

  .site-footer__badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 96px;
    height: 96px;
    border: 1px solid rgba(250, 250, 247, 0.25);
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(250, 250, 247, 0.6);
    line-height: 1.3;
    text-align: center;
  }

  .site-footer__nav h2,
  .site-footer__contact h2 {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 400;
    color: rgba(250, 250, 247, 0.6);
    margin: 0 0 1rem;
  }

  .site-footer__nav ul,
  .site-footer__contact ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.625rem;
  }

  .site-footer__nav a,
  .site-footer__contact a {
    color: var(--color-surface);
    transition: opacity 120ms ease;
  }

  .site-footer__nav a:hover,
  .site-footer__contact a:hover {
    opacity: 0.7;
  }

  .site-footer__meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: rgba(250, 250, 247, 0.5);
  }
</style>
