---
// GDPR cookie banner. Stores consent in localStorage under `pb_consent`.
// GA4 is not loaded until consent is granted (hook up in Base.astro when GA4 ID lands).
---

<div id="cookie-banner" class="cookie-banner" role="region" aria-label="Cookies" hidden>
  <p>
    We use cookies to measure how people use this site. Nothing creepy — just
    anonymous analytics to help us improve.
  </p>
  <div class="cookie-banner__actions">
    <button type="button" data-consent="denied">Decline</button>
    <button type="button" data-consent="granted" class="is-primary">Allow</button>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    left: 1.25rem;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 60;
    background: var(--color-ink);
    color: var(--color-surface);
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    box-shadow: 0 24px 64px -24px rgba(0, 0, 0, 0.4);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.875rem;
    max-width: 520px;
  }

  .cookie-banner[hidden] {
    display: none;
  }

  @media (min-width: 768px) {
    .cookie-banner {
      left: auto;
      flex-direction: row;
      align-items: center;
    }
  }

  .cookie-banner p {
    margin: 0;
    color: rgba(250, 250, 247, 0.8);
    line-height: 1.5;
  }

  .cookie-banner__actions {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .cookie-banner button {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(250, 250, 247, 0.25);
    background: transparent;
    color: var(--color-surface);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: background 120ms ease;
  }

  .cookie-banner button:hover {
    background: rgba(250, 250, 247, 0.08);
  }

  .cookie-banner button.is-primary {
    background: var(--color-brand-purple);
    border-color: var(--color-brand-purple);
  }

  .cookie-banner button.is-primary:hover {
    background: var(--color-brand-purple-hover);
  }
</style>

<script>
  const KEY = 'pb_consent';
  const banner = document.getElementById('cookie-banner');
  if (banner && !localStorage.getItem(KEY)) {
    banner.removeAttribute('hidden');
  }

  banner?.querySelectorAll<HTMLButtonElement>('button[data-consent]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const value = btn.dataset.consent === 'granted' ? 'granted' : 'denied';
      localStorage.setItem(KEY, value);
      banner.setAttribute('hidden', '');
      if (value === 'granted') {
        window.dispatchEvent(new CustomEvent('pb:consent-granted'));
      }
    });
  });
</script>
