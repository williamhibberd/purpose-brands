---
interface Props {
  quote: string;
  shortQuote?: string;
  author: string;
  title: string;
}

const { quote, shortQuote, author, title } = Astro.props;
const displayQuote = shortQuote || quote;
---

<figure class=”testimonial”>
  <blockquote>
    <p>”{displayQuote}”</p>
  </blockquote>
  <figcaption>
    <span class="testimonial__author">{author}</span>
    <span class="testimonial__role">{title}</span>
  </figcaption>
</figure>

<style>
  .testimonial {
    margin: 0;
    padding: 2.5rem;
    background: var(--color-surface-alt);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  :global(.section--dark) .testimonial {
    background: rgba(250, 250, 247, 0.04);
    border: 1px solid var(--color-hairline-dark);
  }

  .testimonial blockquote {
    margin: 0 0 2rem;
    flex: 1;
  }

  .testimonial blockquote p {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.375rem;
    line-height: 1.35;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .testimonial figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-hairline);
  }

  :global(.section--dark) .testimonial figcaption {
    border-top-color: var(--color-hairline-dark);
  }

  .testimonial__author {
    font-weight: 700;
    font-size: 0.9375rem;
  }

  .testimonial__role {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8125rem;
    color: var(--color-mute);
  }
</style>
