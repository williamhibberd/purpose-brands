---
import { getEntry } from 'astro:content';
import { getSettings, getPrimaryContact } from '../lib/site';

const settings = await getSettings();
const primary = await getPrimaryContact();
const contactPage = await getEntry('contact', 'contact');
if (!contactPage) throw new Error('Missing contact content entry');
const { iframeTitle, placeholderHeading, placeholderBody } = contactPage.data.calendly;
const url = settings.calendly;
---

{url ? (
  <div class="calendly">
    <iframe
      src={url}
      title={iframeTitle}
      loading="lazy"
    ></iframe>
  </div>
) : (
  <div class="calendly calendly--placeholder">
    <p>
      <strong>{placeholderHeading}</strong><br />
      {primary.name} {placeholderBody} <a href={`mailto:${primary.email}`}>{primary.email}</a>.
    </p>
  </div>
)}

<style>
  .calendly {
    border: 1px solid var(--color-hairline);
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-surface);
    min-height: 680px;
  }

  .calendly iframe {
    width: 100%;
    height: 680px;
    border: none;
    display: block;
  }

  .calendly--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    padding: 3rem;
    text-align: center;
    background: var(--color-surface-alt);
  }

  .calendly--placeholder p {
    color: var(--color-ink-mute);
    margin: 0;
    line-height: 1.6;
  }

  .calendly--placeholder a {
    color: var(--color-brand-purple);
    text-decoration: underline;
  }
</style>
