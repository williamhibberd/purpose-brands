---
import { getEntry } from 'astro:content';

interface Props {
  brand: string;
  regions: string[];
  engagement: string;
  challenge: string;
  whatWeDid: string;
  results: string[];
  pullQuote?: { quote: string; author: string };
  imageSrc?: string;
  imageAlt?: string;
  href?: string;
  reverse?: boolean;
}

const {
  brand,
  regions,
  engagement,
  challenge,
  whatWeDid,
  results,
  pullQuote,
  imageSrc,
  imageAlt = '',
  href,
  reverse = false,
} = Astro.props;

const workPage = await getEntry('work', 'work');
if (!workPage) throw new Error('Missing work content entry');
const labels = workPage.data.labels;
---

<article class:list={['case-long', reverse && 'case-long--reverse']}>
  <div class="case-long__image">
    {imageSrc ? (
      <img src={imageSrc} alt={imageAlt} loading="lazy" />
    ) : (
      <span class="case-long__placeholder" aria-hidden="true">{brand}</span>
    )}
  </div>

  <div class="case-long__body">
    <h3 class="case-long__title">{brand}</h3>
    <p class="case-long__meta">{regions.join(', ')} &nbsp;|&nbsp; {engagement}</p>

    <div class="case-long__block">
      <h4>{labels.challenge}</h4>
      <p>{challenge}</p>
    </div>

    <div class="case-long__block">
      <h4>{labels.whatWeDid}</h4>
      <p>{whatWeDid}</p>
    </div>

    <div class="case-long__block">
      <h4>{labels.results}</h4>
      <ul>
        {results.map((r) => <li>{r}</li>)}
      </ul>
    </div>

    {pullQuote && (
      <blockquote class="case-long__quote">
        <p>“{pullQuote.quote}”</p>
        <cite>— {pullQuote.author}</cite>
      </blockquote>
    )}

    {href && (
      <a href={href} class="case-long__link">{labels.readMore}</a>
    )}
  </div>
</article>

<style>
  .case-long {
    display: grid;
    gap: 2.5rem;
    padding-block: 4rem;
    border-bottom: 1px solid var(--color-hairline);
  }

  .case-long:last-of-type {
    border-bottom: none;
  }

  @media (min-width: 900px) {
    .case-long {
      grid-template-columns: 5fr 6fr;
      gap: 4rem;
      align-items: start;
    }

    .case-long--reverse .case-long__image {
      order: 2;
    }
  }

  .case-long__image {
    aspect-ratio: 4 / 5;
    background: var(--color-surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    overflow: hidden;
    position: sticky;
    top: 100px;
  }

  @media (max-width: 899px) {
    .case-long__image {
      position: static;
    }
  }

  .case-long__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .case-long__placeholder {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-mute);
  }

  .case-long__title {
    font-size: var(--text-display-md);
    margin: 0 0 0.5rem;
  }

  .case-long__meta {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8125rem;
    color: var(--color-mute);
    margin: 0 0 2.5rem;
    letter-spacing: 0.02em;
  }

  .case-long__block {
    margin-bottom: 2rem;
  }

  .case-long__block h4 {
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-brand-purple);
    margin: 0 0 0.75rem;
  }

  .case-long__block p {
    margin: 0;
    color: var(--color-ink-mute);
    font-size: 1.0625rem;
    line-height: 1.65;
  }

  .case-long__block ul {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--color-ink-mute);
    font-size: 1.0625rem;
    line-height: 1.65;
  }

  .case-long__block li {
    margin-bottom: 0.375rem;
  }

  .case-long__quote {
    margin: 2.5rem 0 0;
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--color-hairline);
  }

  .case-long__quote p {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.375rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
  }

  .case-long__quote cite {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: normal;
    font-size: 0.8125rem;
    color: var(--color-mute);
  }

  .case-long__link {
    display: inline-block;
    margin-top: 2rem;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-brand-purple);
    font-size: 0.875rem;
  }

  .case-long__link:hover {
    text-decoration: underline;
  }
</style>
