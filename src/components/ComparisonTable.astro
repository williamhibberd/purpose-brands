---
interface Props {
  ours: string[];
  theirs: string[];
  ourLabel?: string;
  theirLabel?: string;
}

const {
  ours,
  theirs,
  ourLabel = 'Purpose Brands',
  theirLabel = 'Other Agencies',
} = Astro.props;
---

<div class="comparison">
  <div class="comparison__col comparison__col--ours">
    <h3 class="comparison__label">{ourLabel}</h3>
    <ul>
      {ours.map((item) => (
        <li>
          <span class="comparison__mark" aria-hidden="true">✓</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
  <div class="comparison__col comparison__col--theirs">
    <h3 class="comparison__label">{theirLabel}</h3>
    <ul>
      {theirs.map((item) => (
        <li>
          <span class="comparison__mark comparison__mark--x" aria-hidden="true">×</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .comparison {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--color-hairline);
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-surface);
  }

  :global(.section--dark) .comparison {
    border-color: var(--color-hairline-dark);
    background: transparent;
  }

  @media (min-width: 768px) {
    .comparison {
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }
  }

  .comparison__col {
    padding: 2.5rem;
  }

  .comparison__col--ours {
    background: var(--color-brand-purple);
    color: white;
  }

  .comparison__col--theirs {
    background: var(--color-surface-alt);
  }

  :global(.section--dark) .comparison__col--theirs {
    background: rgba(250, 250, 247, 0.04);
  }

  .comparison__label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0 0 2rem;
    opacity: 0.75;
  }

  .comparison__col--ours .comparison__label {
    color: white;
  }

  .comparison ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
  }

  .comparison li {
    display: flex;
    gap: 0.875rem;
    font-size: 1rem;
    line-height: 1.5;
  }

  .comparison__col--theirs li {
    color: var(--color-ink-mute);
  }

  :global(.section--dark) .comparison__col--theirs li {
    color: rgba(250, 250, 247, 0.7);
  }

  .comparison__mark {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    font-size: 0.75rem;
    line-height: 1;
    margin-top: 0.15rem;
  }

  .comparison__mark--x {
    background: var(--color-hairline);
    color: var(--color-mute);
  }

  :global(.section--dark) .comparison__mark--x {
    background: var(--color-hairline-dark);
  }
</style>
