---
interface Props {
  href: string;
  brand: string;
  headline: string;
  heroStat?: { value: string; label: string };
  imageSrc?: string;
  imageAlt?: string;
}

const { href, brand, headline, heroStat, imageSrc, imageAlt = '' } = Astro.props;
---

<a href={href} class="case-card">
  <div class="case-card__image">
    {imageSrc ? (
      <img src={imageSrc} alt={imageAlt} loading="lazy" />
    ) : (
      <span class="case-card__placeholder" aria-hidden="true">{brand}</span>
    )}
  </div>
  <div class="case-card__body">
    {heroStat && (
      <div class="case-card__stat">
        <span class="case-card__stat-value">{heroStat.value}</span>
        <span class="case-card__stat-label">{heroStat.label}</span>
      </div>
    )}
    <span class="case-card__brand eyebrow">{brand}</span>
    <p class="case-card__headline">{headline}</p>
    <span class="case-card__arrow" aria-hidden="true">Read case study →</span>
  </div>
</a>

<style>
  .case-card {
    display: block;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 260ms ease;
  }

  .case-card:hover {
    transform: translateY(-4px);
  }

  .case-card__image {
    aspect-ratio: 4 / 5;
    background: var(--color-surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 12px;
  }

  .case-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms ease;
  }

  .case-card:hover .case-card__image img {
    transform: scale(1.03);
  }

  .case-card__placeholder {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.75rem;
    color: var(--color-mute);
  }

  .case-card__body {
    padding: 1.5rem 0.25rem 0;
  }

  .case-card__stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-bottom: 1rem;
  }

  .case-card__stat-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-display-md);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-brand-purple);
  }

  .case-card__stat-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-mute);
  }

  .case-card__brand {
    display: block;
    margin-bottom: 0.5rem;
  }

  .case-card__headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
    max-width: 24ch;
  }

  .case-card__arrow {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8125rem;
    color: var(--color-brand-purple);
  }
</style>
